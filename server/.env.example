# Copy this file to `.env` and fill in.
# `server/src/env.ts` loads it on startup; explicit env (e.g. systemd
# Environment=) takes precedence over what's here.

# Google Gemini API key — apply for a free one at
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Optional: override the model. Default is gemini-2.5-flash (Free Tier).
# GEMINI_MODEL=gemini-2.5-flash

# Optional: override server bind. Defaults are 127.0.0.1:3001.
# HOST=127.0.0.1
# PORT=3001

# Optional: SQLite path. Defaults to server/data/app.db.
# DB_PATH=/var/lib/english-learner/app.db
